generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Store {
  id          String            @id @default(cuid())
  shop        String            @unique
  accessToken String
  installedAt DateTime          @default(now())
  isActive    Boolean           @default(true)
  planName    String?
  trialEndsAt DateTime?
  senderEmail String?
  senderName  String?
  smsEnabled  Boolean           @default(false)
  vehicles    CustomerVehicle[]
  reminders   Reminder[]
  products    TrackedProduct[]
}

model CustomerVehicle {
  id            String     @id @default(cuid())
  shop          String
  customerId    String
  customerEmail String
  customerName  String?
  year          Int
  make          String
  model         String
  trim          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  customerPhone String?
  store         Store      @relation(fields: [shop], references: [shop])
  reminders     Reminder[]

  @@index([shop, customerId])
}

model TrackedProduct {
  id               String  @id @default(cuid())
  shop             String
  shopifyProductId String
  productTitle     String
  category         String
  intervalDays     Int
  isActive         Boolean @default(true)
  store            Store   @relation(fields: [shop], references: [shop])

  @@unique([shop, shopifyProductId])
  @@index([shop])
}

model Reminder {
  id              String          @id @default(cuid())
  shop            String
  vehicleId       String
  customerId      String
  customerEmail   String
  productTitle    String
  productCategory String
  scheduledFor    DateTime
  sentAt          DateTime?
  status          ReminderStatus  @default(PENDING)
  channel         String          @default("email")
  messageBody     String?
  customerPhone   String?
  store           Store           @relation(fields: [shop], references: [shop])
  vehicle         CustomerVehicle @relation(fields: [vehicleId], references: [id])

  @@index([shop, status, scheduledFor])
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}
